Для ограничения лишних сетевых соединений я использовал следующие правила iptables

# Generated by iptables-save v1.8.10 (nf_tables) on Fri Oct 10 10:57:05 2025
*filter
:INPUT DROP [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [223:22303]
-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A INPUT -p tcp -m tcp --dport 80 -j ACCEPT
-A INPUT -s 'youripadress'/32 -j ACCEPT
-A INPUT -j DROP
COMMIT
# Completed on Fri Oct 10 10:57:05 2025